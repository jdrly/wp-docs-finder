{
	"name": "wp-docs-finder",
	"version": "0.1.0",
	"description": "Standalone MCP server for searching cached WordPress developer documentation.",
	"type": "module",
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=20.18.1"
	},
	"bin": {
		"wp-docs-finder": "./src/server.js"
	},
	"files": [
		"data",
		"scripts",
		"src",
		"README.md",
		"INSTALL.md"
	],
	"scripts": {
		"docs:update": "node scripts/fetch-docs.js",
		"install:claude-code": "bash scripts/install-claude-code.sh --local",
		"install:codex": "bash scripts/install-codex.sh --local",
		"start": "node src/server.js"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.21.1",
		"cheerio": "^1.1.2",
		"zod": "^3.25.76"
	}
}
